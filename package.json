{
	"name": "react-loaded",
	"version": "1.0.0-beta.1",
	"description": "Auto-generated, SSR-ready skeleton components for React",
	"homepage": "https://github.com/vingt-douze/react-loaded#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/vingt-douze/react-loaded.git"
	},
	"bugs": {
		"url": "https://github.com/vingt-douze/react-loaded/issues"
	},
	"keywords": [
		"react",
		"skeleton",
		"loading",
		"placeholder",
		"layout-shift",
		"cls",
		"ux",
		"ssr",
		"code-generation"
	],
	"author": "vingt-douze <vingt-douze@protonmail.com> (https://vingt-douze.com)",
	"license": "MIT",
	"type": "module",
	"bin": {
		"autoskeleton": "./dist/autoskeleton.js"
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./next": {
			"import": {
				"types": "./dist/next/index.d.ts",
				"default": "./dist/next/index.js"
			},
			"require": {
				"types": "./dist/next/index.d.cts",
				"default": "./dist/next/index.cjs"
			}
		},
		"./next/client": {
			"import": {
				"types": "./dist/next/SkeletonCookieSync.d.ts",
				"default": "./dist/next/SkeletonCookieSync.js"
			},
			"require": {
				"types": "./dist/next/SkeletonCookieSync.d.cts",
				"default": "./dist/next/SkeletonCookieSync.cjs"
			}
		},
		"./style.css": "./dist/index.css"
	},
	"files": [
		"dist"
	],
	"sideEffects": [
		"**/*.css"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint src",
		"format": "biome format --write src",
		"check": "biome check src",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:browser": "vitest run --config vitest.config.browser.ts",
		"release:check": "pnpm run check && pnpm run typecheck && pnpm run test && pnpm run test:browser && pnpm run build",
		"release:pack": "pnpm run release:check && pnpm pack --pack-destination .artifacts",
		"release:npm": "pnpm run release:check && pnpm publish --access public --ignore-scripts",
		"release:npm:dry": "pnpm run release:check && pnpm publish --access public --dry-run --ignore-scripts",
		"release:jsr": "pnpm run release:check && pnpm dlx jsr publish",
		"release:jsr:dry": "pnpm run release:check && pnpm dlx jsr publish --dry-run",
		"release:all": "pnpm run release:check && pnpm publish --access public --ignore-scripts && pnpm dlx jsr publish",
		"prepublishOnly": "pnpm run release:check"
	},
	"peerDependencies": {
		"next": ">=14.0.0",
		"react": "^18.0.0 || ^19.0.0",
		"react-dom": "^18.0.0 || ^19.0.0"
	},
	"peerDependenciesMeta": {
		"next": {
			"optional": true
		}
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.13",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.0",
		"@types/node": "^25.2.3",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitest/browser": "^4.0.18",
		"@vitest/browser-playwright": "^4.0.18",
		"esbuild": "^0.27.3",
		"jsdom": "^29.0.1",
		"next": "16.1.6",
		"playwright": "^1.58.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"sucrase": "^3.35.1",
		"tsup": "^8.0.0",
		"typescript": "^5.7.0",
		"vitest": "^4.0.18"
	}
}
